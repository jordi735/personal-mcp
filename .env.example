MCP_AUTH_TOKEN=
PORT=3000

# GitHub Personal Access Token with "gist" scope (classic) or "Gists: Read and write" (fine-grained).
# Optional — if unset, gist tools are not registered and the server still runs.
GITHUB_PAT=

# Optional override for the User-Agent that read_url sends.
# Defaults to a current desktop Chrome UA, which tends to avoid the anti-bot
# blocks that generic fetch libraries hit.
URL_TOOL_USER_AGENT=
